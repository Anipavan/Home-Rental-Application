# ──────────────────────────────────────────────────────────────────
#  .env.dev — local-dev environment overrides
#
#  Two ways to use this file:
#
#    a) Quick start (don't need this at all):
#         The defaults baked into docker-compose.yml already create
#         a working dev stack — siva / Pavan@123 against the
#         containerised Oracle. Just run:
#           docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build
#         …and ignore this file.
#
#    b) Customised dev (use this file's values):
#         Either rename it to .env (docker compose auto-loads .env),
#         or pass it explicitly on every invocation:
#           docker compose --env-file .env.dev \
#             -f docker-compose.yml -f docker-compose.dev.yml up -d --build
#
#  Anything you put here overrides the ${FOO:-default} fallbacks
#  inside docker-compose.yml. Lines starting with # are ignored.
# ──────────────────────────────────────────────────────────────────

# Spring profile selection — every backend service reads this and
# loads its application-dev.yaml on top of application.yaml.
SPRING_PROFILES_ACTIVE=dev

# ── Oracle container init ─────────────────────────────────────────
# The gvenzl/oracle-free image reads APP_USER + APP_USER_PASSWORD
# on FIRST boot to create a non-SYSDBA application user. Once the
# container has booted with a given pair, changing them here will
# NOT recreate the user — you'd have to wipe the oracle-data volume
# (docker volume rm anirudhhomes_oracle-data) or `ALTER USER` by
# hand. Keep these in sync with DB_USERNAME/DB_PASSWORD below.
ORACLE_PASSWORD=Pavan@123
ORACLE_APP_USER=siva
ORACLE_APP_PASSWORD=Pavan@123

# ── Backend service → Oracle ──────────────────────────────────────
# Service-name DNS works inside the hra-net network, so all backend
# containers reach Oracle via oracle-db:1521.
DB_URL=jdbc:oracle:thin:@//oracle-db:1521/FREEPDB1
DB_USERNAME=siva
DB_PASSWORD=Pavan@123

# ── Gateway CORS ──────────────────────────────────────────────────
# Comma-separated list of origins the gateway's CORS filter accepts.
# Vite uses 4200 by default (see frontend/vite.config.ts), CRA uses
# 3000, modern Vite scaffolds use 5173 — list all three so any
# toolchain works without env juggling.
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:5173

# ── Dev-friendly JWT + internal-auth secrets ──────────────────────
# These match the placeholder strings hard-coded in each service's
# application-dev.yaml so HMAC signatures verify across services
# without any per-service env wrangling. Do NOT use these in prod —
# SecretsBootstrapValidator will refuse to boot a non-dev profile
# with placeholder values still in place.
JWT_SECRET=CHANGE_ME_LOCAL_DEV_JWT_SECRET_PLACEHOLDER_AT_LEAST_32_BYTES_LONG_ABC
INTERNAL_AUTH_SECRET=CHANGE_ME_LOCAL_DEV_INTERNAL_AUTH_SECRET_PLACEHOLDER_AT_LEAST_32_BYTES_LONG
