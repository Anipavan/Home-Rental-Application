# ════════════════════════════════════════════════════════════════════
#  Hearth — production environment template
#
#  Copy this file to `.env` (gitignored) and fill in real values.
#  `docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod.yml up`
#  reads from there; k8s deployments load each section into a Secret
#  per service (see PRODUCTION_READINESS.md P0-2).
#
#  Every value below has a corresponding `${VAR_NAME:CHANGE_ME_*}`
#  placeholder in a service's application.yaml. The
#  SecretsBootstrapValidator (in auth-commons) refuses to start any
#  service under the `prod` profile when the placeholder is still
#  in play — so this list IS the deploy-day checklist.
# ════════════════════════════════════════════════════════════════════

# Active Spring profile. Always `prod` for real deployments; `dev`
# falls back to permissive defaults that are unsafe outside local
# work.
SPRING_PROFILES_ACTIVE=prod

# ─── Database (Oracle) ────────────────────────────────────────────
# Used by every JPA-backed service. In prod, point this at RDS /
# Oracle Cloud / on-prem Oracle. PlanetScale / Neon are NOT
# supported — they're MySQL/Postgres only.
DB_URL=jdbc:oracle:thin:@//db.host.internal:1521/HRA_PROD
DB_USERNAME=hra_app
DB_PASSWORD=CHANGE_ME_TO_A_REAL_DB_PASSWORD

# ─── MongoDB (notification-service) ──────────────────────────────
# Used only by notification-service for the notification log + user
# preferences. Replica set across AZs recommended in prod.
SPRING_DATA_MONGODB_URI=mongodb://mongo.host.internal:27017/hra_notifications

# ─── Kafka ────────────────────────────────────────────────────────
# Comma-separated bootstrap list. MSK / Confluent Cloud / self-hosted
# all work — same wire protocol.
KAFKA_BOOTSTRAP_SERVERS=kafka-1.internal:9092,kafka-2.internal:9092,kafka-3.internal:9092

# ─── Eureka service registry ─────────────────────────────────────
EUREKA_URL=http://eureka.internal:8761/eureka
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=CHANGE_ME_TO_A_REAL_EUREKA_PASSWORD

# ─── JWT (auth-service + api-gateway) ────────────────────────────
# At LEAST 32 characters / 256 bits. Base64-encoded HMAC key.
# Rotate yearly; in-flight tokens stay valid until their `exp` so
# rotation is graceful.
JWT_SECRET=CHANGE_ME_TO_A_REAL_32+_BYTE_BASE64_HMAC_KEY

# ─── Internal-auth signing (every backend service) ──────────────
# HMAC shared between api-gateway and every downstream service.
# auth-commons's GatewayAuthFilter refuses requests that don't
# carry a valid X-Internal-Auth-Sig stamped with this key —
# closes the "anyone on the network can talk directly to a
# downstream service" hole.
INTERNAL_AUTH_SECRET=CHANGE_ME_TO_A_REAL_32+_BYTE_SIGNING_KEY

# ─── PII encryption at rest (user-service) ──────────────────────
# AES-256-GCM key for bank_accounts.account_number (and future
# encrypted PII columns). For real PII protection in prod, source
# from cloud KMS with envelope encryption + a rotation policy.
PII_ENCRYPTION_KEY=CHANGE_ME_TO_A_REAL_32_BYTE_AES_KEY

# ─── Razorpay (payment-service, INR rails) ──────────────────────
# Start with rzp_test_* in staging. Switch to rzp_live_* only after
# webhook delivery is verified end-to-end and an actual ₹1 test
# transaction settles.
RAZORPAY_KEY_ID=rzp_live_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME_TO_A_REAL_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_TO_A_REAL_RAZORPAY_WEBHOOK_SECRET

# ─── Stripe (payment-service, optional international rails) ─────
# Only needed if you sell internationally; leave blank for India-only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Frontend / CORS ────────────────────────────────────────────
# The PUBLIC SPA origin. The api-gateway's CORS filter only allows
# this exact origin (comma-separated for multiple, e.g. staging +
# prod). Wrong value here = every browser request 403s.
CORS_ALLOWED_ORIGINS=https://hearth.app,https://www.hearth.app

# Public base URL the SPA itself is served at. Used by
# notification-service for the sign-in / password-reset links in
# emails. Include the scheme + host; the service appends
# /sign-in or /reset-password.
FRONTEND_URL=https://hearth.app

# ─── Email (notification-service) ───────────────────────────────
# SMTP host for transactional email. AWS SES / SendGrid / Mailgun
# / Postmark all work. Leave blank to disable email entirely
# (notification-service falls back to log-only + in-app bell).
SPRING_MAIL_HOST=email-smtp.ap-south-1.amazonaws.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ─── SMS / WhatsApp (notification-service, Twilio) ──────────────
# Leave blank to disable SMS + WhatsApp legs (in-app + email still
# fire). Twilio test creds work for staging.
APP_TWILIO_ACCOUNT_SID=
APP_TWILIO_AUTH_TOKEN=
APP_TWILIO_SMS_FROM=+11234567890
APP_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Document storage (DocumentationService) ────────────────────
# Public base URL the BROWSER hits to download a presigned
# document URL. In prod, set to your gateway origin.
PUBLIC_BASE_URL=https://api.hearth.app/rentals/v1
# HMAC key the document service signs presigned URLs with.
DOWNLOAD_URL_SECRET=CHANGE_ME_TO_A_REAL_DOWNLOAD_URL_SIGNING_KEY

# ─── OpenTelemetry / tracing ────────────────────────────────────
# OTLP collector endpoint. In k8s usually a DaemonSet / sidecar at
# http://otel-collector.observability:4318. Datadog Agent +
# Honeycomb + Tempo all speak OTLP/HTTP on this URL.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Sampling rate. 0.1 = 10% of traffic. Bump to 1.0 during
# incidents via:
#   MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.1

# ─── Retention scheduler (user-service P1-13) ───────────────────
# Days after soft-delete before a user row is hard-deleted.
APP_RETENTION_SOFT_DELETE_DAYS=30
APP_RETENTION_ENABLED=true

# ─── Auth lockout (auth-service H4) ─────────────────────────────
# Lock the account after 5 failed logins. ON in prod, off in dev.
APP_AUTH_LOCKOUT_ENABLED=true

# ─── Internal-auth enforcement (auth-commons H9) ────────────────
# Must be true in prod. SecretsBootstrapValidator refuses to boot
# with this false under any non-dev profile, but we set it
# explicitly anyway so an operator reading the env file knows
# it's intentional.
INTERNAL_AUTH_ENABLED=true
