# ──────────────────────────────────────────────────────────────────
#  Frontend env template. Copy this to frontend/.env (gitignored)
#  and fill in values for your local / staging / prod build.
#
#  Vite reads env vars at BUILD time, not runtime — so changing
#  these values requires a fresh `npm run build` to take effect.
#  In docker-compose / k8s, set the values as build-args on the
#  frontend image (see frontend/Dockerfile's ARG declarations).
# ──────────────────────────────────────────────────────────────────

# The URL the SPA's axios client uses as its baseURL. Two common
# shapes:
#
#   /api/rentals/v1
#     → use when the SPA is served from the same origin as the
#       gateway (typical: nginx in front of both). The path
#       /api/* is reverse-proxied to the gateway by nginx; see
#       frontend/nginx.conf.
#
#   https://api.anirudhhomes.in/rentals/v1
#     → use when the SPA is on a CDN (Vercel / CloudFront) and
#       the gateway has its own subdomain. CORS_ALLOWED_ORIGINS
#       on the gateway must include the SPA origin.
VITE_API_BASE_URL=/api/rentals/v1

# Optional. Extra origins to add to the CSP connect-src directive —
# typically analytics / error tracking endpoints. Comma-separated.
#   e.g. https://o1234.ingest.sentry.io,https://www.google-analytics.com
VITE_CSP_CONNECT_SRC=

# Optional. When developing through a tunnel (ngrok, cloudflared),
# set this to the tunnel hostname so Vite's allowedHosts check
# accepts the request. Leave blank for plain localhost dev.
VITE_ALLOWED_HOST=
